# Copy this file to .env for local development. Never commit the real .env file.

# MongoDB Atlas connection string (mongodb+srv://user:password@cluster/...)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DATABASE_NAME=greeniem

# Long random secret used to sign admin session JWTs. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Port the Axum backend listens on. Use 3000 for local dev so it matches
# frontend/Trunk.toml's proxy target (`trunk serve` itself runs on 8080).
PORT=3000

# Set to false only for local plain-http development. Must stay true in production
# (Fly.io serves over HTTPS) or the browser will refuse to send the admin cookie.
COOKIE_SECURE=false
